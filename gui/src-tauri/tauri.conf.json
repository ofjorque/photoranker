{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PhotoRanker",
  "version": "0.1.1",
  "identifier": "com.photoranker.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PhotoRanker",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Felrac",
    "copyright": "Copyright © 2026 Felrac",
    "homepage": "https://github.com/ofjorque/photoranker",
    "shortDescription": "Curación fotográfica cuantitativa, inteligente y sin cajas negras",
    "longDescription": "PhotoRanker agrupa las fotos por similitud, las hace competir entre sí con TrueSkill hasta armar un ranking objetivo, y exporta el resultado a sidecars XMP sin tocar los RAW originales — sin ningún modelo de IA opaco decidiendo por detrás.",
    "category": "Photography",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "photoranker.exe"
    ]
  }
}
